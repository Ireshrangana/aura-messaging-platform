{
  "name": "@aura/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/main.ts",
    "admin:preview": "node src/admin-preview.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test src/**/*.spec.ts",
    "openapi:print": "node src/main.ts"
  },
  "dependencies": {
    "@aura/shared": "file:../../packages/shared"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
